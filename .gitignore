# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build output ---
dist/
build/
*.tsbuildinfo
.next/
out/

# --- Environment / secrets ---
# Never commit real secrets. Commit .env.example instead (see README).
.env
.env.local
.env.*.local
!.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test / coverage ---
coverage/
.nyc_output/

# --- Docker / local infra volumes ---
# Postgres, Redpanda, Grafana etc. write data into local volume dirs; never commit those.
.docker-data/
docker-data/

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Go (for the Ledger service, if ADR-0007 is taken up) ---
*.exe
*.test
vendor/
